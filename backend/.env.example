# ══════════════════════════════════════════════════════════════════════════════
# IZ SOLUTION — Backend Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked <CHANGE_ME>
# 3. NEVER commit the real .env file — it is gitignored
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
# Full URL of the deployed frontend (no trailing slash)
FRONTEND_URL=http://localhost:5173

# ── Database (Supabase / PostgreSQL) ──────────────────────────────────────────
# Pooled connection (used by Prisma at runtime — port 6543 transaction pooler
# or port 5432 session mode depending on your network)
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@<POOLER_HOST>:5432/postgres

# Direct connection (used by Prisma migrate — bypasses pooler)
DIRECT_URL=postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@<DIRECT_HOST>:5432/postgres

# ── Supabase API ──────────────────────────────────────────────────────────────
# Settings → General → Reference ID  →  https://<ref>.supabase.co
SUPABASE_URL=https://<PROJECT_REF>.supabase.co

# Settings → API → service_role key  (full access — keep secret)
SUPABASE_SERVICE_KEY=<CHANGE_ME>

# Name of the storage bucket you created in Supabase Storage
SUPABASE_STORAGE_BUCKET=iz-solution

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=<CHANGE_ME_64_CHAR_HEX>
JWT_REFRESH_SECRET=<CHANGE_ME_64_CHAR_HEX_DIFFERENT>
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Email (Brevo SMTP) ────────────────────────────────────────────────────────
# https://app.brevo.com → SMTP & API → SMTP
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=<YOUR_BREVO_SMTP_LOGIN>
SMTP_PASS=<CHANGE_ME>
# Display name and sender address shown in emails
EMAIL_FROM=Iz Solution <noreply@yourdomain.com>

# ── Resend (alternative email provider) ───────────────────────────────────────
# Leave empty if using Brevo above
RESEND_API_KEY=<CHANGE_ME_OR_LEAVE_EMPTY>

# ── Firebase Admin (Google OAuth) ─────────────────────────────────────────────
# Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=<YOUR_FIREBASE_PROJECT_ID>
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@<PROJECT_ID>.iam.gserviceaccount.com
# Paste the full private key including -----BEGIN/END PRIVATE KEY----- lines
# Use \n for newlines when storing in a single-line .env value
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<CHANGE_ME>\n-----END PRIVATE KEY-----\n"

# ── HuggingFace (AI Career Chatbot) ───────────────────────────────────────────
# https://huggingface.co/settings/tokens  (Read token is sufficient)
HUGGINGFACE_API_KEY=<CHANGE_ME>
HUGGINGFACE_MODEL=microsoft/Phi-3.5-mini-instruct

# ── Sentry (Error Tracking) ───────────────────────────────────────────────────
# https://sentry.io → Project Settings → Client Keys (DSN)
# Leave as-is during local development (disabled when value contains 'xxx')
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Minimum quiz score (0–100) required to pass and unlock next lesson
QUIZ_PASS_THRESHOLD=80
