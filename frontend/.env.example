# ══════════════════════════════════════════════════════════════════════════════
# IZ SOLUTION — Frontend Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked <CHANGE_ME>
# 3. All VITE_ variables are embedded in the browser bundle at build time.
#    Do NOT put server-side secrets here.
# ══════════════════════════════════════════════════════════════════════════════

# ── API ───────────────────────────────────────────────────────────────────────
# Full URL of the backend API (no trailing slash)
VITE_API_URL=http://localhost:5000/api

# ── Firebase (Google OAuth — browser SDK) ────────────────────────────────────
# These are CLIENT-SIDE keys, safe to be in the browser bundle.
# Firebase Console → Project Settings → Your Apps → Web App → Config
VITE_FIREBASE_API_KEY=<CHANGE_ME>
VITE_FIREBASE_AUTH_DOMAIN=<YOUR_PROJECT_ID>.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=<YOUR_PROJECT_ID>
VITE_FIREBASE_MESSAGING_SENDER_ID=<CHANGE_ME>
VITE_FIREBASE_APP_ID=<CHANGE_ME>
